# ── Always required ───────────────────────────────────────────────────────────
REDIS_URL=redis://...

# ── Multi-tenant (required for /setup and per-user sync) ─────────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
APP_BASE_URL=https://your-railway-url.up.railway.app

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=

# Google OAuth App (console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-railway-url.up.railway.app/auth/google/callback

# ── Legacy single-tenant CRON (optional if not using old /sync endpoint) ─────
CANVAS_TOKEN=
CANVAS_DOMAIN=byu.instructure.com
SPREADSHEET_ID=
GOOGLE_CREDS_JSON=secret.json
